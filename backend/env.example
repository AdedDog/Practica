# Скопируйте: cp env.example .env

SECRET_KEY=dev-secret-for-local-only

# OTP: true = только консоль uvicorn; false + SMTP ниже = письма через Gmail
DEV_LOG_OTP=true

# Gmail: https://myaccount.google.com/apppasswords (нужна 2FA на аккаунте)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Если 587 таймаутится — укажите SMTP_PORT=465
SMTP_USER=your.name@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FALLBACK_CONSOLE=true
# Необязательно; по умолчанию = SMTP_USER
# SMTP_FROM=IT-Куб <your.name@gmail.com>

ADMIN_EMAIL=your.name@gmail.com
ADMIN_PASSWORD=admin123
